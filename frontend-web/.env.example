# =============================================================================
# FRONTEND WEB (Vite) — Variáveis de ambiente
# Copie para .env e preencha. Ver docs/ENV_SEPARACAO.md (raiz do repo).
# =============================================================================

# URL base da API (verify, admin, recuperar-senha). Produção: URL da API na AWS (ex: https://api.renovejasaude.com.br)
VITE_API_URL=https://api.renovejasaude.com.br

# Formulário de contato (landing): prioridade 1) Formspree, 2) API backend, 3) mailto.
# Formspree: crie em https://formspree.io e defina o email de destino.
# Se vazio e VITE_API_URL definida, usa POST /api/contact (requer SMTP configurado no backend).
VITE_FORMSPREE_FORM_ID=

# Sentry (erros + logs estruturados). Crie projeto em sentry.io → React → copie o DSN.
# Se vazio, Sentry fica desativado.
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
