# =============================================================================
# BACKEND (API .NET) — Variáveis de ambiente
# Copie para .env e preencha. Ver docs/ENV_SEPARACAO.md (raiz do repo).
# Na AWS: Task Definition ou Parameter Store (mesmas chaves).
# =============================================================================

# --- Runtime ---
# Development: aceita localhost, ngrok e IP da LAN automaticamente (AllowedHosts=*).
# Production: em deploy (AWS). Se rodar local com ngrok em Production, use AllowedHosts=* abaixo.
ASPNETCORE_ENVIRONMENT=Production
# Se rodar local com ngrok mantendo Production, descomente para evitar 400 Invalid Hostname (aceita localhost, ngrok, IP):
# AllowedHosts=*
# PORT=8080
# ASPNETCORE_URLS=


# --- API pública ---
Api__BaseUrl=https://api.renovejasaude.com.br
Api__DocumentTokenSecret=CHAVE_MIN_32_CARACTERES

# --- Verificação ITI (QR Code nos PDFs) ---
Verification__BaseUrl=https://api.renovejasaude.com.br/api/verify
Verification__FrontendUrl=https://renovejasaude.com.br/verify
# URL curta no QR (estilo Docway): re.renoveja.com.br ou mesma URL da API
Verification__ShortUrlBase=https://api.renovejasaude.com.br

# --- Google (login) ---
Google__ClientId=SEU_CLIENT_ID.apps.googleusercontent.com

# --- IA: OpenAI GPT (padrão), Gemini (fallback) ---
# Leitura receitas/exames, anamnese, evidências, prescrição, conduta, resumo clínico.
# Transcrição em consulta: Daily.co (Deepgram), não Whisper.
OpenAI__ApiKey=sk-proj-SUA_CHAVE
Gemini__ApiKey=SUA_CHAVE_GEMINI
OpenAI__Model=gpt-4o

# --- Certificado digital ---
CertificateEncryption__Key=SUA_CHAVE_32_BYTES_BASE64

# --- SMTP (e-mail, recuperação de senha) ---
Smtp__Host=smtp.gmail.com
Smtp__Port=587
Smtp__EnableSsl=true
Smtp__UserName=SEU_EMAIL
Smtp__Password=SUA_SENHA_APP
Smtp__FromEmail=SEU_EMAIL
Smtp__FromName=RenoveJá
Smtp__ResetPasswordBaseUrl=https://renovejasaude.com.br/recuperar-senha
# E-mail de destino do formulário de contato (landing). Se vazio, usa contato@renovejasaude.com.br
Smtp__ContactToEmail=contato@renovejasaude.com.br

# --- InfoSimples (validação CRM) ---
InfoSimples__ApiToken=SEU_TOKEN_INFOSIMPLES

# --- Sentry (erros em tempo real) ---
# Crie projeto em sentry.io → .NET → copie o DSN
# Se vazio, Sentry fica desativado (sem efeito)
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# --- Daily.co (videochamada) ---
DAILY_API_KEY=SEU_DAILY_API_KEY
DAILY_DOMAIN=renove
DAILY_ROOM_PREFIX=consult
DAILY_ROOM_EXPIRY_MINUTES=120
# Secret para validar webhooks do Daily (Dashboard Daily → Developers → Webhooks → Secret)
# Quando vazio, webhooks são aceitos sem validação (não recomendado em produção)
DAILY_WEBHOOK_SECRET=
