# =============================================================================
# FRONTEND MOBILE (Expo / React Native) — Variáveis de ambiente
# Copie para .env e preencha. Ver docs/ENV_SEPARACAO.md (raiz do repo).
# =============================================================================

# --- API (URL do backend) ---
# Obrigatório para login, perfil e pedidos. Se inacessível, o cadastro de médico usa lista local de especialidades.
# Em __DEV__, erros de API (ex.: fetchSpecialties) são logados no console (Metro/Expo).
# Produção: URL da API na AWS (ex: https://api.renovejasaude.com.br)
# Produção/custom: https://renovejasaude.com.br
# Dev local: ngrok ou IP da LAN (http://192.168.x.x:5000) — ver docs/APP_NO_CELULAR_EXPO.md
EXPO_PUBLIC_API_URL=https://api.renovejasaude.com.br

# --- Google OAuth (login com Google) ---
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=598286841038-j095u3iopiqltpgbvu0f5od924etobk7.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=598286841038-780e9kksjoscthg0g611virnchlb7kcr.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=598286841038-28ili7c5stg5524sicropmm7s7nkq936.apps.googleusercontent.com

# --- Feature flags ---
EXPO_PUBLIC_TRIAGE_ENABLED=true

# Sentry (erros + logs estruturados). Crie projeto em sentry.io → React Native → copie o DSN.
# Se vazio, Sentry fica desativado.
EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
