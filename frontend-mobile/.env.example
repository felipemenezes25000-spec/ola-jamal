# =============================================================================
# FRONTEND MOBILE (Expo / React Native) — Variáveis de ambiente
# Copie para .env e preencha. Ver docs/ENV_SEPARACAO.md (raiz do repo).
# Não coloque aqui chaves do backend (Supabase service key, etc.).
# =============================================================================

# --- API (URL do backend) ---
# Obrigatório para login, perfil e pedidos. Se inacessível, o cadastro de médico usa lista local de especialidades.
# Em __DEV__, erros de API (ex.: fetchSpecialties) são logados no console (Metro/Expo).
# Render: https://ola-jamal.onrender.com (acessível de qualquer lugar)
# Produção/custom: https://renovejasaude.com.br
# Dev local: ngrok ou IP da LAN (http://192.168.x.x:5000) — ver docs/APP_NO_CELULAR_EXPO.md
EXPO_PUBLIC_API_URL=https://ola-jamal.onrender.com

# --- Google OAuth (login com Google) ---
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=598286841038-j095u3oipijggbrdu5ad924etobk7.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=598286841038-78oe9kposcithgpq01yrmchib7kcr.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=598286841038-z8j875stgi35s24ecropmm7s7akpd30.apps.googleusercontent.com

# --- Feature flags ---
EXPO_PUBLIC_TRIAGE_ENABLED=true
